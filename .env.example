# Server Configuration
PORT=4000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=meetza
DB_PORT=3306

# Authentication
JWT_SECRET=your_jwt_secret_key

# Email Configuration (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# URLs
